# Google Device Access / SDM
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
SDM_PROJECT_ID=your-sdm-project-id
PUBSUB_PROJECT_ID=your-gcp-project-id
PUBSUB_SUBSCRIPTION_ID=barkup-events

# Cameras (comma-separated device IDs, or "all" for all linked cameras)
# Run `PYTHONPATH=src python3 -m barkup.main --list-devices` to find IDs
CAMERA_DEVICE_IDS=enterprises/PROJECT_ID/devices/DEVICE_ID
# Friendly names (optional, comma-separated matching order above)
# CAMERA_NAMES=Indoor,Backyard

# Notion
NOTION_API_KEY=secret_your-notion-integration-token
NOTION_DATABASE_ID=920423d6-8283-4e48-bf5f-aa024ba5b22c

# Bark Detection Tuning
BARK_CONFIDENCE_THRESHOLD=0.3
EPISODE_COOLDOWN_SECONDS=30

# Clip Storage (optional - local by default)
CLIP_STORAGE_PATH=./clips
# S3_ENDPOINT=https://fsn1.your-objectstorage.com
# S3_BUCKET=barkup-clips
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
